---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
  <div class="flex min-h-screen items-center justify-center bg-background">
    <div class="text-center">
      <h1 class="mb-4 text-6xl font-bold text-gradient">404</h1>
      <p class="mb-6 text-xl text-muted-foreground">Oops! Page not found</p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:opacity-90 transition-opacity"
      >
        Return to Home
      </a>
    </div>
  </div>
</Layout>
